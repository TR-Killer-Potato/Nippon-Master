rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Scorecard Document Matcher
    match /artifacts/{appId}/users/{userId}/scorecard/{docId} {
      // Allow single-document retrieval and writes for authenticated owners
      allow get: if isOwner(userId) && isValidId(appId) && isValidId(userId) && isValidId(docId);
      allow create, update: if isOwner(userId) && isValidScorecard(incoming()) && isValidId(appId) && isValidId(userId) && isValidId(docId);
      allow delete: if isOwner(userId);
    }

    // Reusable Global Helpers
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidScorecard(data) {
      // Must contain scores key, which is locked to map form
      return data.keys().hasAll(['scores']) && data.scores is map;
    }
  }
}
